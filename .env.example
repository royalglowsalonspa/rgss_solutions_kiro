# ═══════════════════════════════════════════════════════════════════
# Royal Glow Salon & SPA — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Neon PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host-direct/dbname?sslmode=require

# ─── Authentication (Better Auth) ────────────────────────────────
BETTER_AUTH_SECRET=your-32-char-secret-here-change-this
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email (Resend — Transactional) ──────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="Royal Glow <contact@theroyalglow.in>"

# ─── Email (Brevo — Marketing) ───────────────────────────────────
BREVO_API_KEY="xkeysib-your-brevo-api-key"

# ─── Realtime (Ably) ─────────────────────────────────────────────
ABLY_API_KEY="your-ably-api-key"

# ─── Cache & Queue (Upstash) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# ─── Background Jobs (QStash) ────────────────────────────────────
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"
QSTASH_URL="https://qstash.upstash.io"

# ─── File Storage (Cloudflare R2) ────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="rgss-uploads"
CLOUDFLARE_R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL="https://cdn.theroyalglow.in"

# ─── Cloudflare (KV + Workers) ───────────────────────────────────
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_KV_NAMESPACE_ID="your-kv-namespace-id"

# ─── Meta Pixel & Conversions API ────────────────────────────────
META_PIXEL_ACCESS_TOKEN="your-meta-pixel-access-token"

# ─── Web Push Notifications ──────────────────────────────────────
WEB_PUSH_PRIVATE_KEY="your-vapid-private-key"

# ─── Error Monitoring (Sentry) ───────────────────────────────────
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="royal-glow"
SENTRY_PROJECT="rgss-web"

# ─── Observability (BetterStack) ─────────────────────────────────
BETTERSTACK_SOURCE_TOKEN="your-betterstack-source-token"
BETTERSTACK_HEARTBEAT_URL="https://uptime.betterstack.com/api/v1/heartbeat/your-id"

# ─── CMS (Payload) ───────────────────────────────────────────────
PAYLOAD_SECRET="your-payload-secret-min-32-chars"
CMS_URL="http://localhost:3001"

# ─── CI/CD ────────────────────────────────────────────────────────
SKIP_ENV_VALIDATION="false"

# ═══════════════════════════════════════════════════════════════════
# Client-Side Variables (NEXT_PUBLIC_ prefix)
# These are exposed to the browser — never put secrets here
# ═══════════════════════════════════════════════════════════════════

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ABLY_KEY="your-ably-public-key"
NEXT_PUBLIC_META_PIXEL_ID="your-meta-pixel-id"
NEXT_PUBLIC_POSTHOG_KEY="phc_your-posthog-project-key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY="your-vapid-public-key"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
