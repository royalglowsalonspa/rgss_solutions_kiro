        "lineHeight": 1.03,
        "letterSpacing": "-1.44px"
      },
      "$type": "typography",
      "$description": "h-display — largest headline, hero sections"
    },
    "heading-xl": {
      "$value": {
        "fontFamily": "Cabinet Grotesk",
        "fontSize": "clamp(32px, 4.5vw, 48px)",
        "fontWeight": 900,
        "lineHeight": 1.1,
        "letterSpacing": "-0.96px"
      },
      "$type": "typography",
      "$description": "h-xl — section headlines"
    },
    "heading-md": {
      "$value": {
        "fontFamily": "Cabinet Grotesk",
        "fontSize": "28px",
        "fontWeight": 800,
        "lineHeight": 1.15,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "h-md — subsection headlines"
    },
    "body-lg": {
      "$value": {
        "fontFamily": "Clash Grotesk",
        "fontSize": "17px",
        "fontWeight": 400,
        "lineHeight": 1.6,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Body Large — hero descriptions, lead paragraphs"
    },
    "body": {
      "$value": {
        "fontFamily": "Clash Grotesk",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.55,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Body — default paragraph text"
    },
    "small": {
      "$value": {
        "fontFamily": "Clash Grotesk",
        "fontSize": "13px",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Small — captions, metadata, footer text"
    },
    "eyebrow": {
      "$value": {
        "fontFamily": "Plus Jakarta Sans",
        "fontSize": "11px",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "2px",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "Eyebrow — section labels, category headers"
    },
    "button": {
      "$value": {
        "fontFamily": "Plus Jakarta Sans",
        "fontSize": "12px",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "0.5px",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "Button — all CTA buttons, nav links"
    },
    "nav": {
      "$value": {
        "fontFamily": "Plus Jakarta Sans",
        "fontSize": "12px",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "0.5px",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "Nav — header navigation links"
    },
    "pill": {
      "$value": {
        "fontFamily": "Plus Jakarta Sans",
        "fontSize": "11px",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "1px",
        "textTransform": "uppercase"
      },
      "$type": "typography",
      "$description": "Pill/Tag — category tags, status badges"
    }
