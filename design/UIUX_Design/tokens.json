    "elevated": {
      "$value": "0 24px 50px -20px rgba(26, 15, 10, 0.45)",
      "$type": "shadow",
      "$description": "Featured/elevated cards"
    }
  },
  "layout": {
    "page-max-width": { "$value": "1278px", "$type": "dimension" },
    "container-padding": { "$value": "20px", "$type": "dimension" },
    "section-gap": { "$value": "80px", "$type": "dimension" },
    "card-padding": { "$value": "16px", "$type": "dimension" },
    "card-padding-lg": { "$value": "32px", "$type": "dimension" },
    "element-gap": { "$value": "24px", "$type": "dimension" }
  }
