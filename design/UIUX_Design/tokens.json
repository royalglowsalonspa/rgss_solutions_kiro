      "$value": "#C8A961",
      "$type": "color",
      "$description": "Links, numerals, primary hover, outlines, decorative borders"
    },
    "warm-gold": {
      "$value": "#F4E09B",
      "$type": "color",
      "$description": "Alias of royal-gold — primary action fill"
    },
    "warm-stone": {
      "$value": "#D4C5A9",
      "$type": "color",
      "$description": "Muted gold neutral — subtle decorative strokes, icon outlines"
    },
    "warm-cream": {
      "$value": "#FFF8E7",
      "$type": "color",
      "$description": "Hero secondary card background, CTA section background"
    },
    "golden-mist": {
      "$value": "#FFF3D4",
      "$type": "color",
      "$description": "Announcement bar background, pill hover background"
    },
    "canvas-white": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Page background — dominant bright canvas"
    },
    "cocoa-dark": {
      "$value": "#1A0F0A",
      "$type": "color",
      "$description": "Primary text, dark hero card background — rich chocolaty black"
    },
    "rich-chocolate": {
      "$value": "#2D1810",
      "$type": "color",
      "$description": "Offer cards background — elevated dark accent"
    },
    "warm-gray": {
      "$value": "#3D2E1F",
      "$type": "color",
      "$description": "Body / secondary text — chocolate-tinted dark neutral"
    },
    "dusty-gray": {
      "$value": "#8C8C8C",
      "$type": "color",
      "$description": "Tertiary text, timestamps — use only at ≥18px on white"
    },
    "outline-gray": {
      "$value": "#CCCCCC",
      "$type": "color",
      "$description": "Inactive dot indicators, hairline borders, dividers"
    },
    "cloud-gray": {
      "$value": "#F4F5F9",
      "$type": "color",
      "$description": "Card borders, dividers, ghost button background"
    },
    "success": {
      "$value": "#3F7D5C",
      "$type": "color",
      "$description": "Confirmations, positive states"
