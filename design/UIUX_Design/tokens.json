{
  "$extensions": {
    "com.royalglow.design": {
      "brand": "Royal Glow Salon & SPA",
      "theme": "Royal Warmth",
      "version": "2.0.0",
      "updatedAt": "2026-05-30T00:00:00.000Z",
      "fonts": {
        "display": "Cabinet Grotesk (Fontshare)",
        "sans": "Clash Grotesk (Fontshare)",
        "ui": "Plus Jakarta Sans (Google Fonts)"
      }
    }
  },
