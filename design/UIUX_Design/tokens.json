      "$value": "Cabinet Grotesk",
      "$type": "fontFamily",
      "$description": "Headlines H1-H3, brand wordmark. Weight 900 (Black). Source: Fontshare."
    },
    "sans": {
      "$value": "Clash Grotesk",
      "$type": "fontFamily",
      "$description": "Body text, descriptions, quotes. Weight 400 (Regular). Source: Fontshare."
    },
    "ui": {
      "$value": "Plus Jakarta Sans",
      "$type": "fontFamily",
      "$description": "Buttons, nav links, tag pills, badges, eyebrows. Weight 700 (Bold). Source: Google Fonts."
    }
  },
