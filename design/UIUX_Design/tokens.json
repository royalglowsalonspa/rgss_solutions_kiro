  "spacing": {
    "4": { "$value": "4px", "$type": "dimension" },
    "8": { "$value": "8px", "$type": "dimension" },
    "12": { "$value": "12px", "$type": "dimension" },
    "14": { "$value": "14px", "$type": "dimension" },
    "16": { "$value": "16px", "$type": "dimension" },
    "20": { "$value": "20px", "$type": "dimension" },
    "24": { "$value": "24px", "$type": "dimension" },
    "32": { "$value": "32px", "$type": "dimension" },
    "40": { "$value": "40px", "$type": "dimension" },
    "48": { "$value": "48px", "$type": "dimension" },
    "64": { "$value": "64px", "$type": "dimension" },
    "80": { "$value": "80px", "$type": "dimension" }
  },
  "radius": {
    "default": { "$value": "4px", "$type": "dimension", "$description": "Default small radius" },
    "cards": { "$value": "6px", "$type": "dimension", "$description": "Cards, hero blocks, sections" },
    "buttons": { "$value": "8px", "$type": "dimension", "$description": "Reserved — pills preferred" },
    "testimonial": { "$value": "10px", "$type": "dimension", "$description": "Review cards only" },
    "pill": { "$value": "9999px", "$type": "dimension", "$description": "Buttons, pills, avatars, dots" }
