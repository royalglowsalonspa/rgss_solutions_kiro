    "warning": {
      "$value": "#C8A961",
      "$type": "color",
      "$description": "Warning states — reuses deep-gold"
    },
    "error": {
      "$value": "#B5482E",
      "$type": "color",
      "$description": "Form errors, destructive actions"
    },
    "accent-pink": {
      "$value": "#F8C8D8",
      "$type": "color",
      "$description": "Review avatar circles"
    }
